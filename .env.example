APP_NAME="Grid Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# LLM — Google Gemini (gratuito, sem cartão: https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VERIFY_SSL=false # Defina como "true" para verificar o certificado SSL (recomendado para produção)
